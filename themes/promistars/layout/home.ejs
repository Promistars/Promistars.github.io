<%
const profile = site.data.profile;
const lang = profile.zh;
const year = new Date().getFullYear();
const routePath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
const pageKey = routePath.startsWith('intro') ? 'intro' : routePath.startsWith('resume') ? 'resume' : routePath.startsWith('navigator') ? 'navigator' : 'about';
const pageData = lang.pages[pageKey];
const pageUrl = pageKey === 'about' ? `${config.url}/about/` : `${config.url}/${pageKey}/`;
const navAttr = key => key === pageKey ? ' class="is-active" aria-current="page"' : '';
%>
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= pageData.metaTitle %></title>
    <meta name="description" content="<%= pageData.description || lang.description %>">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= pageData.metaTitle %>">
    <meta property="og:description" content="<%= pageData.description || lang.description %>">
    <meta property="og:url" content="<%= pageUrl %>">
    <meta property="og:site_name" content="<%= config.title %>">
    <meta name="twitter:card" content="summary">
    <link rel="canonical" href="<%= pageUrl %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Ma+Shan+Zheng&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css?v=20260616-sidebar-dock">
  </head>
  <body data-page="<%= pageKey %>">
    <canvas class="ambient-canvas" id="ambient" aria-hidden="true"></canvas>
    <figure class="hero-art" aria-hidden="true">
      <img src="/images/hero-science.png" alt="">
    </figure>
    <header class="site-header">
      <a class="brand" href="/about/" data-name><%= lang.name %></a>
      <nav class="nav-links" aria-label="Primary navigation">
        <a href="/about/" data-nav-page="about"<%- navAttr('about') %>><%= lang.pages.about.heading %></a>
        <a href="/intro/" data-nav-page="intro"<%- navAttr('intro') %>><%= lang.pages.intro.heading %></a>
        <a href="/resume/" data-nav-page="resume"<%- navAttr('resume') %>><%= lang.pages.resume.heading %></a>
        <button class="lang-toggle" type="button" data-lang-toggle><%= lang.nav.langSwitch %></button>
      </nav>
      <div class="sidebar-footer">
        <div class="utility-grid" data-dock-grid>
          <% lang.dock.items.forEach(item => { %>
            <a class="utility-icon" href="<%= item.href %>" aria-label="<%= item.label %>" title="<%= item.label %>" data-dock-key="<%= item.key %>">
              <img src="<%= item.icon %>" alt="">
            </a>
          <% }) %>
        </div>
        <p class="sidebar-copy"><span><%= year %> ©</span><span data-dock-copyright><%= lang.dock.copyright %></span></p>
      </div>
    </header>

    <main>
      <% if (pageKey === 'about') { %>
        <div class="sci-fi-field" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <section class="hero page-hero" id="hero">
          <div class="hero-copy">
            <p class="eyebrow" data-page-eyebrow><%= pageData.eyebrow %></p>
            <h1 class="hero-name" data-name><%= lang.name %></h1>
            <div class="name-note" aria-label="Name meaning">
              <span class="name-seal" aria-hidden="true">璋</span>
              <p data-name-meaning><%= lang.nameMeaning %></p>
            </div>
            <p class="role" data-page-role><%= pageData.role %></p>
            <p class="tagline" data-page-lead><%= pageData.lead %></p>
            <div class="hero-actions">
              <a class="button primary" href="/intro/" data-about-cta-intro><%= pageData.ctaIntro %></a>
              <a class="button secondary" href="/resume/" data-about-cta-resume><%= pageData.ctaResume %></a>
            </div>
          </div>
          <aside class="hero-card" aria-label="Profile highlights" data-about-metrics>
            <% pageData.metrics.forEach(metric => { %>
              <div>
                <span class="metric-label"><%= metric.label %></span>
                <strong><%= metric.value %></strong>
                <span><%= metric.note %></span>
              </div>
            <% }) %>
          </aside>
        </section>

        <section class="section" id="highlights">
          <div class="section-title">
            <span>01</span>
            <h2 data-about-highlights-title><%= pageData.highlightsTitle %></h2>
          </div>
          <div class="honor-grid value-grid" data-about-highlights>
            <% pageData.highlights.forEach((item, index) => { %>
              <article class="panel honor-card value-card">
                <h3><%= String(index + 1).padStart(2, '0') %></h3>
                <p><%= item %></p>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (pageKey === 'intro') { %>
        <section class="hero page-hero intro-hero" id="hero">
          <div class="hero-copy">
            <p class="eyebrow" data-page-eyebrow><%= pageData.eyebrow %></p>
            <h1 data-page-heading><%= pageData.heading %></h1>
            <p class="tagline" data-page-lead><%= pageData.lead %></p>
            <div class="hero-actions">
              <a class="button primary" href="/resume/" data-intro-cta-resume><%= pageData.ctaResume %></a>
            </div>
          </div>
        </section>

        <section class="section" id="intro">
          <div class="intro-stack" data-intro-blocks>
            <% pageData.blocks.forEach((block, index) => { %>
              <article class="panel intro-card">
                <span><%= String(index + 1).padStart(2, '0') %></span>
                <div>
                  <h2><%= block.title %></h2>
                  <p><%= block.body %></p>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (pageKey === 'resume') { %>
        <section class="hero page-hero resume-hero" id="hero">
          <div class="hero-copy">
            <p class="eyebrow" data-page-eyebrow><%= pageData.eyebrow %></p>
            <h1 data-page-heading><%= pageData.heading %></h1>
            <p class="tagline" data-page-lead><%= pageData.lead %></p>
          </div>
        </section>

        <section class="section" id="education">
          <div class="section-title">
            <span>01</span>
            <h2 data-education="title"><%= lang.education.title %></h2>
          </div>
          <div class="education-grid">
            <article class="panel education-main">
              <h3 data-education="school"><%= lang.education.school %></h3>
              <p class="accent" data-education="degree"><%= lang.education.degree %></p>
              <ul>
                <li><span data-education="college1"><%= lang.education.college1 %></span> · <span data-education="college2"><%= lang.education.college2 %></span></li>
                <li data-education="intensive"><%= lang.education.intensive %></li>
                <li data-education="minor"><%= lang.education.minor %></li>
              </ul>
            </article>
            <aside class="panel education-stat">
              <p data-education="period"><%= lang.education.period %></p>
              <strong data-education="gpaHighlight"><%= lang.education.gpaHighlight %></strong>
              <span data-education="gpaMajor"><%= lang.education.gpaMajor %></span>
              <small data-education="gpaOverall"><%= lang.education.gpaOverall %></small>
            </aside>
          </div>
        </section>

        <section class="section" id="projects">
          <div class="section-title">
            <span>02</span>
            <h2 data-projects-title><%= lang.projects.title %></h2>
          </div>
          <div class="project-list" data-project-list></div>
        </section>

        <section class="section" id="honors">
          <div class="section-title">
            <span>03</span>
            <h2 data-honors-title><%= lang.honors.title %></h2>
          </div>
          <div class="honor-grid" data-honor-grid></div>
        </section>

        <section class="section" id="leadership">
          <div class="section-title">
            <span>04</span>
            <h2 data-leadership-title><%= lang.leadership.title %></h2>
          </div>
          <div class="timeline" data-leadership-list></div>
        </section>

        <section class="section contact-section" id="contact">
          <div class="section-title">
            <span>05</span>
            <h2 data-contact="title"><%= lang.contact.title %></h2>
          </div>
          <div class="panel contact-panel">
            <div class="contact-lines">
              <div>
                <p class="field-label" data-contact="emailLabel"><%= lang.contact.emailLabel %></p>
                <a class="contact-link" href="#" data-email-link></a>
                <button class="small-button" type="button" data-copy-email><%= lang.contact.copy %></button>
              </div>
              <div>
                <p class="field-label" data-contact="phoneLabel"><%= lang.contact.phoneLabel %></p>
                <span class="contact-link" data-phone-value><%= lang.contact.phoneMasked %></span>
                <button class="small-button" type="button" data-phone-toggle><%= lang.contact.revealPhone %></button>
              </div>
            </div>
            <p class="contact-note" data-contact="footnote"><%= lang.contact.footnote %></p>
          </div>
        </section>
      <% } %>

      <% if (pageKey === 'navigator') { %>
        <section class="hero page-hero navigator-hero" id="hero">
          <div class="hero-copy">
            <p class="eyebrow" data-page-eyebrow><%= pageData.eyebrow %></p>
            <h1 data-page-heading><%= pageData.heading %></h1>
            <p class="tagline" data-page-lead><%= pageData.lead %></p>
          </div>
        </section>

        <section class="section" id="navigator">
          <div class="panel navigator-panel">
            <h2 data-navigator-empty-title><%= pageData.emptyTitle %></h2>
            <p data-navigator-empty-text><%= pageData.emptyText %></p>
          </div>
        </section>
      <% } %>
    </main>

    <script>
      window.__PROFILE__ = <%- JSON.stringify(profile) %>;
      window.__PAGE_KEY__ = "<%= pageKey %>";
    </script>
    <script src="/js/site.js?v=20260616-sidebar-dock"></script>
  </body>
</html>
